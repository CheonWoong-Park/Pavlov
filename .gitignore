*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
htmlcov/

# Virtual environments and local dependency state
.venv/
venv/
env/
ENV/
__pypackages__/
.python-version

# Local secrets and machine-specific config
.env
.env.*
!.env.example
.claude/
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs and transient run output
*.log
logs/*.log
runs/
outputs/
wandb/
mlruns/

