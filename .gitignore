# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
htmlcov/

# Virtual environments and local dependency state
.venv/
venv/
env/
ENV/
__pypackages__/
.python-version

# Local secrets and machine-specific config
.env
.env.*
!.env.example
.claude/
.vscode/
.idea/
*.swp
*.swo

# Credentials / private keys (never commit)
*.pem
*.key

# OS files
.DS_Store
Thumbs.db

# Logs and transient run output
*.log
logs/*.log
runs/
outputs/
wandb/
mlruns/

# Model checkpoints and ML artifacts
checkpoints/*
!checkpoints/.gitkeep
*.ckpt
*.pt
*.pth
*.safetensors
*.onnx
*.bin

# Project data artifacts
data/bulk
data/raw/*
!data/raw/.gitkeep
data/binaries/*
!data/binaries/.gitkeep
data/pseudocode/*
!data/pseudocode/.gitkeep
data/anonymized/*
!data/anonymized/.gitkeep

# Binary/archive inputs produced or downloaded during experiments
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
*.o
*.obj
*.so
*.dll
*.dylib
*.exe

# Ghidra project artifacts
*.gpr
*.rep

# Nested external repository metadata
tools/LLM4Decompile/.git/
results/*_gen.jsonl
results/*_filled.jsonl
results/*_reexec.jsonl
results/*smoke*

# Result dumps and local experiment outputs (kept locally, not in git)
eval_pull_*/
checkpoints_run2/
figures/
poster_draft.md

# Large matched datasets (regenerable; kept locally, not in git)
data/matched/*.jsonl
